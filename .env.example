# ─────────────────────────────────────────────────────────────────────────────
# Crewmate — Environment Variables
# Copy this file to .env and fill in your values:  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Gemini API key — get one free at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# 32-character random string for encrypting stored secrets
# Generate:  openssl rand -hex 16
CREWMATE_ENCRYPTION_KEY=

# ── SERVER ────────────────────────────────────────────────────────────────────

PORT=8787
CORS_ORIGIN=http://localhost:3000
REQUEST_BODY_LIMIT=25mb
CREWMATE_DB_PATH=data/crewmate.db
AUTH_EXPOSE_DEV_CODE=true
CREWMATE_COMMAND_TOKEN=
FEATURE_UI_NAVIGATOR=false

# ── MODEL OVERRIDES (optional) ────────────────────────────────────────────────

# GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
# GEMINI_TEXT_MODEL=gemini-3.1-flash-lite-preview
# GEMINI_RESEARCH_MODEL=gemini-3.1-pro-preview
# GEMINI_ORCHESTRATION_MODEL=gemini-3.1-pro-preview
# GEMINI_CREATIVE_MODEL=gemini-3.1-flash-image-preview
# GEMINI_LITE_MODEL=gemini-3.1-flash-lite-preview

# ── SEARCH (optional but recommended) ────────────────────────────────────────
# Tavily: AI-optimized web search used by Research, Sales, Marketing, Legal, Data agents.
# Free tier: 1,000 searches/month. Get key: https://app.tavily.com
# Without this, Crewmate falls back to DuckDuckGo (free, no key needed).
TAVILY_API_KEY=

# ── GOOGLE OAUTH (for Gmail + Calendar skills) ────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Scopes needed: gmail.readonly, gmail.send, calendar.events, calendar.readonly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/api/auth/gmail/callback
GOOGLE_REDIRECT_URI_CALENDAR=http://localhost:8787/api/auth/calendar/callback

# Frontend API URL (used by Vite)
VITE_API_URL=http://localhost:8787
VITE_ENABLE_CONSERVATIVE_LIVE_TURN_TAKING=true

# ── GITHUB ────────────────────────────────────────────────────────────────────
# Personal Access Token → https://github.com/settings/tokens
# Scopes: repo, issues, pull_requests
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# ── SLACK ─────────────────────────────────────────────────────────────────────
# Bot token (xoxb-...) for posting messages via slack.post-message skill
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL_ID=

# ── TELEGRAM ──────────────────────────────────────────────────────────────────
# Create a bot with @BotFather, then paste the bot token here.
# DEFAULT_CHAT_ID should be the one Telegram chat allowed to control Crewmate.
# WEBHOOK_SECRET should match the secret token you register with Telegram webhooks.
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# ── NOTION ────────────────────────────────────────────────────────────────────
# Integration Token → https://www.notion.so/my-integrations
NOTION_TOKEN=""
NOTION_PARENT_PAGE_ID=""

# ── CLICKUP ───────────────────────────────────────────────────────────────────
CLICKUP_TOKEN=""
CLICKUP_LIST_ID=""

# ── GCP DEPLOYMENT (optional) ─────────────────────────────────────────────────
# Used by cloud-deploy.sh and Dockerfile
# GCP_PROJECT_ID=your-project-id
# GCP_REGION=us-central1
# GCP_SERVICE_NAME=crewmate
