# ─────────────────────────────────────────────────────────────────────────────
# Crewmate — Environment Variables
# Copy this file to .env and fill in your values:  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Gemini API key — get one free at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# 32-character random string for encrypting stored integration secrets
# Generate:  openssl rand -hex 16
CREWMATE_ENCRYPTION_KEY=

# ── SERVER ────────────────────────────────────────────────────────────────────

PORT=8787
CORS_ORIGIN=http://localhost:3000
PUBLIC_APP_URL=http://localhost:8787
PUBLIC_WEB_APP_URL=http://localhost:3000
REQUEST_BODY_LIMIT=25mb
CREWMATE_DB_PATH=data/crewmate.db
CREWMATE_ARTIFACTS_PATH=data/artifacts
AUTH_EXPOSE_DEV_CODE=true
CREWMATE_COMMAND_TOKEN=
SCREENSHOT_SHARE_TTL_MS=3600000

# ── FEATURE FLAGS ─────────────────────────────────────────────────────────────

# Set to true to enable the Playwright-powered browser/UI navigation agent
FEATURE_UI_NAVIGATOR=true
# Set to true to require human approval before high-impact skill execution
FEATURE_APPROVAL_GATES=false
# Set to true to receive inbound Slack commands (requires SLACK_SIGNING_SECRET)
FEATURE_SLACK_INBOUND=false

# ── FRONTEND ──────────────────────────────────────────────────────────────────

# Backend API base URL (used by Vite dev server)
VITE_API_URL=http://localhost:8787
VITE_ENABLE_CONSERVATIVE_LIVE_TURN_TAKING=true
VITE_ENABLE_DIRECT_LIVE=false

# ── MODEL OVERRIDES (optional) ────────────────────────────────────────────────
# Defaults are set in server/config.ts. Only override if you need a specific version.

# GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
# GEMINI_TEXT_MODEL=gemini-2.5-flash-lite
# GEMINI_RESEARCH_MODEL=gemini-2.5-pro
# GEMINI_ORCHESTRATION_MODEL=gemini-2.5-pro
# GEMINI_CREATIVE_MODEL=gemini-2.5-flash-image-preview
# GEMINI_LITE_MODEL=gemini-2.5-flash-lite

# ── FIREBASE AUTH (production) ────────────────────────────────────────────────
# Required for production deployments. Skip for local dev (magic code login works without it).
# Create a service account at https://console.firebase.google.com → Project Settings → Service accounts
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MEASUREMENT_ID=

# ── SEARCH (optional but recommended) ────────────────────────────────────────
# Tavily: AI-optimized web search used by Research, Sales, Marketing, Legal, Data agents.
# Free tier: 1,000 searches/month. Get key: https://app.tavily.com
# Without this, Crewmate falls back to DuckDuckGo (free, no key needed).
TAVILY_API_KEY=

# ── GOOGLE WORKSPACE (Gmail, Calendar, Docs, Sheets, Slides, Drive) ───────────
# Create OAuth client at https://console.cloud.google.com → APIs & Services → Credentials
# Scopes: gmail.readonly, gmail.send, calendar.events, drive, docs, sheets, slides
GOOGLE_WORKSPACE_CLIENT_ID=
GOOGLE_WORKSPACE_CLIENT_SECRET=
GOOGLE_WORKSPACE_REDIRECT_URI=http://localhost:8787/api/integrations/google-workspace/callback

# ── NOTION ────────────────────────────────────────────────────────────────────
# Create an internal integration at https://www.notion.so/my-integrations
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=
# OAuth (for multi-user / hosted deployments)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8787/api/integrations/notion/callback

# ── SLACK ─────────────────────────────────────────────────────────────────────
# Create a Slack app at https://api.slack.com/apps
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL_ID=
SLACK_SIGNING_SECRET=
# OAuth (for multi-workspace support)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8787/api/integrations/slack/callback

# ── CLICKUP ───────────────────────────────────────────────────────────────────
# Get token at https://app.clickup.com/settings/apps
CLICKUP_TOKEN=
CLICKUP_LIST_ID=
# OAuth (for multi-user / hosted deployments)
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=
CLICKUP_REDIRECT_URI=http://localhost:8787/api/integrations/clickup/callback

# ── GITHUB ────────────────────────────────────────────────────────────────────
# Personal Access Token → https://github.com/settings/tokens
# Scopes needed: repo, issues, pull_requests
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
